rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /usuarios/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.nome is string;

      allow read, update: if isOwner(userId);
      allow delete: if false;
    }

    match /historico/{registroId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.acertos is number
        && request.resource.data.erros is number
        && request.resource.data.pontuacao is number
        && request.resource.data.tempo is number
        && request.resource.data.nivel in ['facil', 'medio', 'dificil']
        && request.resource.data.tema in ['pokemon', 'mario', 'biblioteca'];

      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
